# Supabase — project URL e publishable key (anon)
# Pegar em: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service role (opcional, somente pra operações privilegiadas em servidor)
SUPABASE_SERVICE_ROLE_KEY=

# Resend (opcional, pra emails de confirmação)
RESEND_API_KEY=

# URL pública do app
NEXT_PUBLIC_APP_URL=https://noronhadelivery.com.br
