# Supabase — project URL e publishable key (anon)
# Pegar em: https://supabase.com/dashboard/project/<ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=

# Resend — para email de pré-cadastro (contato@noronhadelivery.com)
RESEND_API_KEY=

# Mercado Pago — apenas PIX
# Painel: https://www.mercadopago.com.br/developers/panel
NEXT_PUBLIC_MP_PUBLIC_KEY=APP_USR-xxx
MP_ACCESS_TOKEN=APP_USR-xxx
MP_CLIENT_ID=xxx
MP_CLIENT_SECRET=xxx

# Stripe — cartão + Apple Pay + Google Pay
# Dashboard: https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_RESTRICTED_KEY=rk_live_xxx

# URL pública do app
NEXT_PUBLIC_APP_URL=https://noronhadelivery.com
